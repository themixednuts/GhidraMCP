#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "[pre-commit] Running format checks..."
just fmt-check

echo "[pre-commit] Running unit tests..."
just test

echo "[pre-commit] Running end-to-end tests..."
just test-e2e

echo "[pre-commit] All checks passed."
